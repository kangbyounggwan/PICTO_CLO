# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# SerpAPI (실시간 웹 검색용)
SERPAPI_KEY=your-serpapi-key

# Telegram Bots (3개)
MARKY_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
SERVO_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
SCOUT_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Group/Chat ID (선택사항)
TELEGRAM_GROUP_ID=-1001234567890

# 팀원 Telegram User IDs (권한 관리용)
CEO_USER_ID=123456789
CTO_USER_ID=987654321

# Database
DATABASE_PATH=./database/bot.db

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash-lite
